# node_modules/@prisma/client  ← included in node_modules above

# ── Logs ──────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── Test coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── OS ────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
