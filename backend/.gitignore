# ── Dependencies ──────────────────────────────────────────────────────────
node_modules/

# ── Environment (never commit secrets) ────────────────────────────────────
.env
.env.local
.env.*.local

# ── Build output ──────────────────────────────────────────────────────────
dist/

# ── SQLite database files ─────────────────────────────────────────────────
*.db
*.db-journal
*.db-shm
*.db-wal

